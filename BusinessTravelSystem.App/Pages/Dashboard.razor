    private sealed record DashboardModule(
        string Key,
        string Label,
        string Title,
        string Description,
        string PrimaryAction,
        int OpenItems,
        string OpenSummary,
        int MonthlyTotal,
        string MonthSummary,
        string[] Activities,
        int NotificationCount);

    private sealed record TripRecord(
        string City,
        string Country,
        string Owner,
        string DateRange,
        string TripType,
        int Travelers,
        double MapX,
        double MapY);

    private sealed record MetricCard(string Title, int Local, int Overseas, string ToneClass);

    private sealed record CostItem(string Label, string ToneClass);

    private sealed record MonthlyTrip(string Label, int Count, int Height);

    private sealed record ActiveTraveler(string Name, string Destination, string Department)
    {
        public string Initials => string.Concat(Name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(part => part[0])).ToUpperInvariant();
    }

    private sealed record CalendarDay(string Label, bool IsMuted, bool IsToday, ActiveTraveler[] Travelers)
    {
        public bool HasTravelers => Travelers.Length > 0;
    }
}
